# Lumora Portal — environment variable reference
# Copy this file and fill in values. Store secrets in Replit Secrets, not here.

# === Replit-managed (set automatically, do not set manually) ===
# DATABASE_URL=

# === Required — set in Replit shared env ===
PORT=8080
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_STAFF_ROLE_ID=your_staff_role_id_here

# === Required — store in Replit Secrets ===
SESSION_SECRET=change_me_to_a_long_random_string
DISCORD_CLIENT_ID=your_discord_oauth_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token

# === Optional — store in Replit Secrets ===
# OPENROUTER_API_KEY=      # Enables AI bot-repair and error-explanation features
# OPENROUTER_MODEL=openai/gpt-4o-mini

# === Optional — store in Replit Secrets ===
# ADMIN_PASSWORD=          # Defaults to "lumora-admin" — CHANGE before going live
# DISCORD_TICKET_CATEGORY_NAME=Tickets
